# ── 必須 ────────────────────────────────────────────────────────────────────
# サーバー側にのみ保持すること
OPENAI_API_KEY=sk-proj-replace-me

# セッションCookie署名用のランダム文字列（32バイト以上）
SESSION_SECRET=replace-with-at-least-32-random-bytes

# ── ユーザー認証 ─────────────────────────────────────────────────────────────
# シードユーザーのアクセスID（カンマ区切り・管理画面で削除不可）
ALLOWED_LOGIN_IDS=team_7KQ4-9W2P,staff_K8LA-2M9X

# シードユーザーの初期パスワードハッシュ（npm run hash-password -- <PASSWORD>）
# SEED_USER_PASSWORD_HASH=

# プレーンテキストIDの代わりにSHA-256ハッシュを使う場合（推奨）
# npm run hash-id -- team_7KQ4-9W2P
# ALLOWED_LOGIN_ID_HASHES=

# ── 管理者 ───────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com

# npm run hash-password -- your-secure-password
# 形式: iterations:salt:hash（.env内で $ を使わないこと）
# ADMIN_PASSWORD_HASH=

# ── オプション ───────────────────────────────────────────────────────────────
OPENAI_REALTIME_MODEL=gpt-realtime
AUTH_MAX_ATTEMPTS=8
AUTH_WINDOW_MS=900000
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Cloudflare Pages Functions ────────────────────────────────────────────
# OPENAI_API_KEY と SESSION_SECRET は encrypted secret として登録
# ALLOWED_LOGIN_IDS または ALLOWED_LOGIN_ID_HASHES は環境変数として登録
# KV namespace SESSION_KV をバインド
