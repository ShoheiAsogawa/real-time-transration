# Required: keep this only on the server.
OPENAI_API_KEY=sk-proj-replace-me

# Strong random value for signing httpOnly session cookies.
SESSION_SECRET=replace-with-at-least-32-random-bytes

# Invite-only login IDs. Use long, random IDs; anyone with one can log in.
ALLOWED_LOGIN_IDS=team_7KQ4-9W2P,staff_K8LA-2M9X

# Recommended for production: store SHA-256 hashes instead of plaintext IDs.
# Generate one with: npm run hash-id -- team_7KQ4-9W2P
# ALLOWED_LOGIN_ID_HASHES=

# Realtime model and login abuse controls.
OPENAI_REALTIME_MODEL=gpt-realtime
AUTH_MAX_ATTEMPTS=8
AUTH_WINDOW_MS=900000

# Add your HTTPS production origin here.
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Cloudflare Pages Functions:
# - Add OPENAI_API_KEY and SESSION_SECRET as encrypted secrets.
# - Add ALLOWED_LOGIN_IDS or ALLOWED_LOGIN_ID_HASHES as environment variables.
# - Bind a KV namespace named SESSION_KV.
